{
  "version": 2,
  "builds": [
    {
      "src": "server/dist/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "ui/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/dist/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "ui/dist/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "SERVE_UI": "true"
  }
}